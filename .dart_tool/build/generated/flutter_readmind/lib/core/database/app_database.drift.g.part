    Expression<int>? id,
    Expression<int>? bookId,
    Expression<int>? chapterIndex,
    Expression<int>? pageNumber,
    Expression<double>? scrollPosition,
    Expression<double>? progressPercent,
    Expression<int>? readingMinutes,
