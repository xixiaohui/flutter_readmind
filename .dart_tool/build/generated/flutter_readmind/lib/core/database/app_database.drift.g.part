class GeneratedPoster extends DataClass implements Insertable<GeneratedPoster> {
  /// 主键 ID
  final int id;

  /// 高亮 ID（外键）
  final int highlightId;

  /// 引用文本
  final String quoteText;

  /// 书名
  final String? bookTitle;

  /// 作者
  final String? author;

  /// 模板键
  final String? templateKey;

  /// 比例 (1:1, 4:5, 9:16)
  final String? ratio;

  /// 图片路径
  final String? imagePath;

  /// 创建时间
  final int createdAt;
  const GeneratedPoster(
      {required this.id,
      required this.highlightId,
      required this.quoteText,
      this.bookTitle,
      this.author,
      this.templateKey,
      this.ratio,
      this.imagePath,
      required this.createdAt});
  @override
  Map<String, Expression> toColumns(bool nullToAbsent) {
    final map = <String, Expression>{};
    map['id'] = Variable<int>(id);
    map['highlight_id'] = Variable<int>(highlightId);
    map['quote_text'] = Variable<String>(quoteText);
    if (!nullToAbsent || bookTitle != null) {
      map['book_title'] = Variable<String>(bookTitle);
    }
    if (!nullToAbsent || author != null) {
      map['author'] = Variable<String>(author);
    }
    if (!nullToAbsent || templateKey != null) {
      map['template_key'] = Variable<String>(templateKey);
    }
    if (!nullToAbsent || ratio != null) {
      map['ratio'] = Variable<String>(ratio);
    }
    if (!nullToAbsent || imagePath != null) {
      map['image_path'] = Variable<String>(imagePath);
    }
    map['created_at'] = Variable<int>(createdAt);
    return map;
  }

  GeneratedPostersCompanion toCompanion(bool nullToAbsent) {
    return GeneratedPostersCompanion(
      id: Value(id),
      highlightId: Value(highlightId),
      quoteText: Value(quoteText),
      bookTitle: bookTitle == null && nullToAbsent
          ? const Value.absent()
          : Value(bookTitle),
      author:
          author == null && nullToAbsent ? const Value.absent() : Value(author),
      templateKey: templateKey == null && nullToAbsent
          ? const Value.absent()
          : Value(templateKey),
      ratio:
          ratio == null && nullToAbsent ? const Value.absent() : Value(ratio),
      imagePath: imagePath == null && nullToAbsent
          ? const Value.absent()
          : Value(imagePath),
      createdAt: Value(createdAt),
    );
  }

