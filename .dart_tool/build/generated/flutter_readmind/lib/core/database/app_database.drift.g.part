      quoteText: serializer.fromJson<String>(json['quoteText']),
      bookTitle: serializer.fromJson<String?>(json['bookTitle']),
      author: serializer.fromJson<String?>(json['author']),
      templateKey: serializer.fromJson<String?>(json['templateKey']),
      ratio: serializer.fromJson<String?>(json['ratio']),
      imagePath: serializer.fromJson<String?>(json['imagePath']),
      createdAt: serializer.fromJson<int>(json['createdAt']),
    );
